{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist-electron",
    "rootDir": "src/client",
    "types": ["node"]
  },
  "include": ["src/client/main.ts", "src/client/preload.cts", "src/client/bridge.ts"]
}
